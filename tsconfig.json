    "target": "ES2019",
    "module": "commonjs",
    "rootDir": ".",
    "moduleResolution": "node",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "validator/**/*.ts",
    "validator/**/*.test.ts"
  ]
}